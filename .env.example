# Server Monitoring local config
HM_PORT=3002
HM_HOST=127.0.0.1
HM_ADMIN_USER=admin
HM_ADMIN_PASS=change-this-password
HM_SESSION_SECRET=change-this-long-random-string

# Optional Hermes chat history. If this file does not exist, Chat UI is hidden.
HM_STATE_DB=/home/ubuntu/.hermes/state.db

# Local metrics history DB
HM_HISTORY_DB=./data/metrics-history.sqlite
HM_HISTORY_INTERVAL_MS=60000
HM_DB_CACHE_TTL_MS=15000
HM_METRICS_INTERVAL_MS=5000
